{
  "model": "opusplan",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(~/.claude/enable-safe-yolo.sh *)",
      "Bash(~/.claude/disable-safe-yolo.sh *)"
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "jdtls-lsp@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "superpowers@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "hookify@anthropics/claude-code": false,
    "feature-dev@anthropics/claude-code": false,
    "pr-review-toolkit@anthropics/claude-code": false,
    "claude-md-management@claude-plugins-official": false,
    "claude-mem@thedotmack": false,
    "obsidian@obsidian-skills": false,
    "ui-ux-pro-max@ui-ux-pro-max-skill": false,
    "context-mode@context-mode": false
  },
  "env": {
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "e=$(printf '\\n---\\n## %s — [Auto-Compact Snapshot]\\n**Session:** %s\\n**CWD:** %s\\n**Note:** Run /log-context for full detail if not already done.\\n' \"$(date '+%Y-%m-%d %H:%M:%S')\" \"${CLAUDE_SESSION_ID:-unknown}\" \"${PWD}\"); if [ -f tasks/tracker.md ]; then tmp=$(mktemp) && { head -3 tasks/tracker.md; printf '%s\\n' \"$e\"; tail -n +4 tasks/tracker.md; } > \"$tmp\" && mv \"$tmp\" tasks/tracker.md; else printf '%s\\n' \"$e\" > tasks/tracker.md; fi 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "~/.claude/scripts/limit-watchdog.sh" },
          { "type": "command", "command": "~/.claude/scripts/aidlc-guard.sh" }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "~/.claude/scripts/limit-watchdog.sh" },
          { "type": "command", "command": "~/.claude/scripts/aidlc-guard.sh" }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f ~/.claude/.handover-ready ] && echo 'Handover marker found — run /init-context to resume your last session.' || true"
          },
          {
            "type": "command",
            "command": "reset_file=\"$HOME/.claude/.ollama-reset-time\"; override=\"$HOME/.claude/.ollama-override\"; if [ -f \"$override\" ] && [ -f \"$reset_file\" ]; then reset_epoch=$(cat \"$reset_file\" 2>/dev/null | tr -d '[:space:]'); now_epoch=$(date '+%s'); if [ -n \"$reset_epoch\" ] && [ \"$now_epoch\" -ge \"$reset_epoch\" ] 2>/dev/null; then rm -f \"$override\" \"$reset_file\" \"$HOME/.claude/.handover-ready\"; echo \"[info] Anthropic limit has reset — Ollama override cleared automatically. You are now on Anthropic.\"; fi; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$HOME/.claude/.ollama-override\" ] && [ -f \"$HOME/.claude/.ollama-reset-time\" ]; then reset_epoch=$(cat \"$HOME/.claude/.ollama-reset-time\" | tr -d '[:space:]'); now_epoch=$(date '+%s'); remaining=$((reset_epoch - now_epoch)); if [ \"$remaining\" -le 300 ] && [ \"$remaining\" -gt 0 ]; then echo \"WARNING: Anthropic limit resets in $((remaining / 60)) min — run /log-context NOW to preserve session state.\"; fi; fi"
          },
          { "type": "command", "command": "~/.claude/scripts/claudeignore-guard.sh" }
        ]
      }
    ]
  },
  "mcpServers": {
    "context7": {
      "type": "url",
      "url": "https://mcp.context7.com/mcp",
      "disabled": false
    },
    "gitnexus": {
      "command": "npx",
      "args": [
        "-y",
        "gitnexus@latest",
        "mcp"
      ],
      "disabled": true
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${HOME}"
      ],
      "disabled": true
    },
    "vercel": {
      "type": "url",
      "url": "https://mcp.vercel.com",
      "disabled": true
    },
    "supabase": {
      "type": "url",
      "url": "https://mcp.supabase.com/mcp",
      "disabled": true
    },
    "claude-mem": {
      "type": "url",
      "url": "http://localhost:37777/mcp",
      "disabled": true
    },
    "context-mode": {
      "command": "npx",
      "args": [
        "-y",
        "context-mode"
      ],
      "disabled": true
    }
  }
}