# claude-local-starter .gitignore
# Standard blacklist — track everything except the patterns below.

# ── Generated at install time ───────────────────────────────────
plugin_commands.sh

# ── Machine-specific snapshots ──────────────────────────────────
token-audit-state.json

# ── macOS metadata ──────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Large binary / media files ──────────────────────────────────
*.mp4
!screenshots/html_preview.mp4
*.mov
*.avi

# ── Node (if any local tooling is added to the repo) ────────────
node_modules/

# ── Tool-generated session directories ──────────────────────────
.claude/
.playwright-cli/


# ── AIDLC design, tracking and auditing docs (per-machine session notes, not repo source) ──────────
docs/
audit/
tasks/

# ── Backup files (generated during development/install, not repo source) ──────
*-bkp.sh
*-bkp.json

# Intermediate Notes
TALK-PLAN.md
LOCAL-MODEL-TRANSITION-PLAN.md
history.jsonl
